{
  "name": "pw-mcp-proxy",
  "version": "1.0.0",
  "description": "Transparent multi-profile MCP proxy for @playwright/mcp: one tool set + switch/current/restart_profile, isolated per-identity backends, self-healing (leak/lock), zero runtime deps.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "bin": {
    "pw-mcp-proxy": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "test": "vitest run",
    "test:pure": "vitest run --config vitest.pure.config.js",
    "test:mut": "stryker run",
    "test:spec": "node spec/check.mjs",
    "dup": "jscpd .",
    "arch": "depcruise --config .dependency-cruiser.cjs .",
    "coupling": "npm run dup && npm run arch"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/vitest-runner": "^8.7.1",
    "dependency-cruiser": "^18.0.0",
    "fast-check": "^3.23.1",
    "jscpd": "^5.0.12",
    "vitest": "^3.2.7"
  }
}
